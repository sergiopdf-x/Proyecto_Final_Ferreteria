<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="750.0" styleClass="app" stylesheets="@estilos/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ferreteria.controller.ProductoController">

    <top>
        <Label styleClass="seccion-titulo" stylesheets="@estilos/estilos.css" text="Gestion de Inventario" />
    </top>

    <left>
        <VBox prefWidth="260" spacing="10" style="-fx-padding: 0 12 12 18;">
            <VBox spacing="8" styleClass="form-panel">
                <Label styleClass="formulario-label" text="Codigo de barra" />
                <TextField fx:id="txtCodigo" styleClass="campos-txt" stylesheets="@estilos/estilos.css" />
                <Label styleClass="formulario-label" text="Nombre" />
                <TextField fx:id="txtNombre" styleClass="campos-txt" stylesheets="@estilos/estilos.css" />
                <Label styleClass="formulario-label" text="Marca" />
                <TextField fx:id="txtMarca" styleClass="campos-txt" stylesheets="@estilos/estilos.css" />
                <Label styleClass="formulario-label" text="Precio" />
                <TextField fx:id="txtPrecio" styleClass="campos-txt" stylesheets="@estilos/estilos.css" />
                <Label styleClass="formulario-label" text="Stock" />
                <TextField fx:id="txtStock" styleClass="campos-txt" />

                <HBox spacing="8">
                    <Button onAction="#registrarProducto" styleClass="boton-guardar" stylesheets="@estilos/estilos.css" text="Guardar" />
                    <Button onAction="#modificarProducto" styleClass="boton-modificar" stylesheets="@estilos/estilos.css" text="Modificar" />
                </HBox>
                <HBox spacing="8">
                    <Button onAction="#eliminarProducto" styleClass="boton-eliminar" stylesheets="@estilos/estilos.css" text="Eliminar" />
                    <Button onAction="#limpiarCampos" styleClass="boton-limpiar" stylesheets="@estilos/estilos.css" text="Limpiar" />
                </HBox>
                <Button maxWidth="Infinity" onAction="#volverDashboard" styleClass="boton-volver" text="Volver al menu" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-padding: 0 18 18 0;">
            <TableView fx:id="tablaProductos" styleClass="tabla-view" stylesheets="@estilos/estilos.css" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="40" text="ID" />
                    <TableColumn fx:id="colCodigo" prefWidth="90" text="Codigo" />
                    <TableColumn fx:id="colNombre" prefWidth="150" text="Nombre" />
                    <TableColumn fx:id="colMarca" prefWidth="100" text="Marca" />
                    <TableColumn fx:id="colPrecio" prefWidth="80" text="Precio" />
                    <TableColumn fx:id="colStock" prefWidth="70" text="Stock" />
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
