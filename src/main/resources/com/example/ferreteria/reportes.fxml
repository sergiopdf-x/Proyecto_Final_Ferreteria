<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.ferreteria.controller.ReportesController"
            prefHeight="500.0" prefWidth="750.0">

    <top>
        <VBox spacing="5" style="-fx-padding:10;">
            <Label style="-fx-font-size:18; -fx-font-weight:bold;" text="Reporte de Ventas"/>
            <Label fx:id="lblTotalVendido" style="-fx-font-size:14;" text="Total vendido: $0.00"/>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tablaReporte">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                <TableColumn fx:id="colProducto" text="Producto" prefWidth="180"/>
                <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="80"/>
                <TableColumn fx:id="colTotal" text="Total" prefWidth="90"/>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="150"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <Button style="-fx-padding:10;" onAction="#volverDashboard" text="Volver al menu"/>
    </bottom>

</BorderPane>
